 def swapPairs(self, head: Optional[ListNode]) -> Optional[ListNode]:
        if not head or not head.next:
            return head
        
        curr1 = head#state is fine
        curr2 = head.next
        if head:
            curr1.next = self.swapPairs(curr2.next)
            curr2.next  = curr1
            
        
        return curr2
